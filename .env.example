# ── Copy this file to .env and fill in your values ──

# ── MongoDB (raw API cache — WHOIS/GSB/scrape responses) ──
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
DB_NAME=truxera

# ── PostgreSQL (primary relational database) ──────────────
DATABASE_URL=postgresql+asyncpg://truxera:password@localhost:5432/truxera

# ── Redis (search quota, trust score cache, rate limiting) ─
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this

# ── External APIs ─────────────────────────────────────────
# Get free key from whoisxmlapi.com
WHOIS_API_KEY=your-whois-api-key

# Get from Google Cloud Console → Safe Browsing API
GOOGLE_SAFE_BROWSING_KEY=your-google-key
